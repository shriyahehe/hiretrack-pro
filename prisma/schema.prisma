generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())

  
}

model Candidate {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phone       String?
  position    String
  experience  Int
  status      String   @default("Applied")
  resumeUrl   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}