generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())

  candidates Candidate[]
}

model Candidate {
  id          String           @id @default(cuid())
  fullName    String
  email       String
  phone       String
  position    String
  experience  Int
  resumeUrl   String?
  notes       String?
  status      CandidateStatus  @default(APPLIED)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User @relation(fields: [userId], references: [id])
}